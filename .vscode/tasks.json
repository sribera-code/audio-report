{
  // Génère l'audio du fichier .txt actuellement ouvert.
  // Raccourci : Ctrl+Shift+B  (ou : Terminal > Run Build Task).
  // La sortie va dans audio/<nom-du-fichier>.mp3
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Générer l'audio (fichier courant, voix Piper siwis-medium)",
      "type": "shell",
      "command": "python",
      "args": [
        "generate_audio.py",
        "${file}",
        "--engine", "piper",
        "--voice", "${env:USERPROFILE}\\.local\\share\\piper\\voices\\fr_FR-siwis-medium.onnx",
        "--output", "audio/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONUTF8": "1",
          "PATH": "C:\\Users\\riber\\tools\\ffmpeg-8.1.1-essentials_build\\bin;${env:PATH}"
        }
      },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    }
  ]
}
